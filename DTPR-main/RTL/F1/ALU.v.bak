module alu (
input wire [31:0] A,// Primer operando
input wire [31:0] B, // Segundo operando
input wire [2:0] ALUct1,// Control de la ALU de tres bits para seleccionar la operaciůn
output reg [31:0] R,// Resultado de la operaciůn
output reg zero// SeŮal de cero (1 si el resultado es cero, caso contrario
0 en
);
always @(*) begin
case (ALUct1)
3'b0000: R = A + B; // Suma
3'60001: R = A
B; // Resta
3'b0010: R = A
B; // OR
3'b0011: R = A & B; // AND
3'b0100: R = ($signed (A) < $signed (B)) ? 1 : 0; // SLT
($signed) para comparar como nķmeros con signo
default: R = 32'b0; // Valor por defecto
endcase
end
assign zero
endmodule
=
(R
0) 2 10; // SeŮal de cero
