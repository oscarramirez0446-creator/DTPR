module memoria (
input wire clk, // Reloj
input wire we, // Seńal de escritura (1 para escribir, 0 para leer)
input wire [31:0] addr, // Dirección de memoria
input wire [31:0] wd, // Dato a escribir en memoria
output reg [31:0] rd // Dato leído de memoria
reg [31:0] mem [0:1023]; // Memoria de 1024 palabras de 32 bits
always @(posedge clk) begin // En el flanco positivo del reloj if (we) begin // Si la seńal de escritura está activa mem [addr [11:2]] <= wd; // Escribir el dato en la dirección especificada (usando solo los bits relevantes para direccionar palabras)
end else begin
especificada
end
rd <= mem [addr [11:2]]; // Leer el dato de la dirección
end
endmodule
