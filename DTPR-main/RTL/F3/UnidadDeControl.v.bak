module UnidadDeControl(
    input [31:26] op,
    output reg MemToReg,
    output reg MemWrite,
    output reg MemToRead,
    output reg [2:0] ALUop,
    output reg RegWrite
);

always @(*)
begin
    case (op)

        // Instrucciones tipo R
        6'b000000:
        begin
            MemToReg   = 1'b0;
            ALUop      = 3'b010;
            MemToRead  = 1'b0;
            MemToWrite = 1'b0;
            RegWrite   = 1'b1;
        end

        // Valor por defecto
        default:
        begin
            MemToReg   = 1'b0;
            ALUop      = 3'b000;
            MemToRead  = 1'b0;
            MemToWrite = 1'b0;
            RegWrite   = 1'b0;
        end

    endcase
end

endmodule
