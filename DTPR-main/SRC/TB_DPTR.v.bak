module TB_DPTR;

// =====================================
// Seńal de reloj
// =====================================

reg clk;

// =====================================
// Instancia del módulo principal DPTR
// =====================================

DPTR uut (
    .clk(clk)
);

// =====================================
// Generador de reloj
// =====================================

initial
begin
    clk = 1'b0;
end

always
begin
    #5 clk = ~clk;
end

// =====================================
// Simulación principal
// =====================================

initial
begin
    $display("====================================");
    $display("   INICIO DE SIMULACION DPTR");
    $display("====================================");

    // Tiempo suficiente para ejecutar
    // las 10 instrucciones:
    // 0, 4, 8, 12, 16, 20, 24, 28, 32, 36

    #120;

    $display("====================================");
    $display("   FIN DE SIMULACION");
    $display("====================================");

    $stop;
end

endmodule